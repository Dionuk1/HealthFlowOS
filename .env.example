# Server
PORT=5500

# MongoDB (required)
MONGO_URI=mongodb://127.0.0.1:27017/healthflow_os

# Auth (required) — use a long, random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-long-random-string

# AES-256 (required) — must be exactly 32 bytes:
# - 64 hex characters (e.g. openssl rand -hex 32), OR
# - base64 encoding of 32 bytes (e.g. openssl rand -base64 32)
MEDICAL_AES_KEY=change-me-64-hex-chars-or-base64-of-32-bytes

# ✨ AI FEATURES (Optional - AI works without these, but with enhanced features using Gemini)
# Get free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=auto

# Fraud Detection & Security
MAX_REQUESTS_PER_MINUTE=60
MAX_FAILED_LOGINS=5
BAN_DURATION_MINUTES=15
ADMIN_IPS=127.0.0.1

# Node Environment
NODE_ENV=development

# Seed script credentials (used by: npm run seed)
# Set strong passwords before running the seed script in any shared environment.
SEED_ADMIN_EMAIL=admin@healthflow.test
SEED_ADMIN_PASSWORD=change-me-admin-password

SEED_DOCTOR_EMAIL=doctor@healthflow.test
SEED_DOCTOR_PASSWORD=change-me-doctor-password

SEED_PATIENT_EMAIL=patient@healthflow.test
SEED_PATIENT_PASSWORD=change-me-patient-password

# Shared password used for all additional seed patients and doctors.
SEED_DEFAULT_PASSWORD=change-me-default-seed-password

