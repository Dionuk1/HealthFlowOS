# Server
PORT=5500

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/healthflow_os

# Seed (local demo accounts)
# Optional: set a stable password used by `npm run seed`
# If omitted, the seed script generates one and prints it.
SEED_DEFAULT_PASSWORD=<CHOOSE_A_PASSWORD>

# Auth
JWT_SECRET=change-me-long-random-string

# AES-256 (32 bytes) for medical data encryption simulation
# Use one of:
# - 64 hex characters
# - base64 encoding of 32 bytes

# ✨ AI FEATURES (Optional - AI works without these, but with enhanced features using Gemini)
# Get free API key from: https://makersuite.google.com/app/apikey
# Install Gemini package: npm install @google/generative-ai
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=auto

# Fraud Detection & Security
MAX_REQUESTS_PER_MINUTE=60
MAX_FAILED_LOGINS=5
BAN_DURATION_MINUTES=15
ADMIN_IPS=127.0.0.1

# Node Environment
NODE_ENV=development

